FROM python:3.11-slim

WORKDIR /app

COPY --from=ghcr.io/astral-sh/uv:latest /uv /bin/uv

COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev

COPY frontend/ ./frontend/

ENV API_URL=http://api:8000   # will be overridden later

EXPOSE 7860

CMD uv run streamlit run frontend/app.py --server.port=7860 --server.address=0.0.0.0